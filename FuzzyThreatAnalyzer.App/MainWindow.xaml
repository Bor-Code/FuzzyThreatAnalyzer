<Window x:Class="FuzzyThreatAnalyzer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="FuzzyThreatAnalyzer Dashboard"
        Width="1550"
        Height="920"
        MinWidth="1300"
        MinHeight="820"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#0B1120">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <SolidColorBrush x:Key="SidebarBackground" Color="#111827"/>
        <SolidColorBrush x:Key="CardBackground" Color="#172033"/>
        <SolidColorBrush x:Key="CardBorder" Color="#2F3B52"/>
        <SolidColorBrush x:Key="InputBackground" Color="#0B1220"/>
        <SolidColorBrush x:Key="PrimaryText" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="SecondaryText" Color="#9CA3AF"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#2563EB"/>
        <SolidColorBrush x:Key="AccentTeal" Color="#0F766E"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="39"/>
            <Setter Property="Margin" Value="0,6,0,13"/>
            <Setter Property="Padding" Value="11,6"/>
            <Setter Property="Background" Value="{StaticResource InputBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="43"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="NavRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="52"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryText}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="#111827"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2563EB"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#60A5FA"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#60A5FA"/>
                                <Setter TargetName="Root" Property="Background" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="#E5E7EB"/>
                            </Trigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="#2563EB"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#93C5FD"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#0B1220"/>
            <Setter Property="AlternatingRowBackground" Value="#111827"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#334155"/>
            <Setter Property="VerticalGridLinesBrush" Value="#334155"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="FuzzyThreatAnalyzer"
                           FontSize="34"
                           FontWeight="Bold"/>

                <TextBlock Text="Explainable fuzzy logic-based threat analysis and visualization dashboard"
                           FontSize="15"
                           Foreground="{StaticResource SecondaryText}"
                           Margin="0,5,0,0"/>
            </StackPanel>

            <Border Grid.Column="1"
                    Background="#111827"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="18,10"
                    VerticalAlignment="Center">
                <TextBlock Text="Fuzzy Logic • Threat Scoring • Reports"
                           Foreground="{StaticResource SecondaryText}"
                           FontSize="14"/>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="355"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource SidebarBackground}"
                    BorderBrush="{StaticResource CardBorder}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="22">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Analysis Inputs"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Sample name" FontSize="13" Foreground="{StaticResource SecondaryText}"/>
                        <TextBox x:Name="SampleNameTextBox" Text="demo-malware"/>

                        <TextBlock Text="Static score" FontSize="13" Foreground="{StaticResource SecondaryText}"/>
                        <TextBox x:Name="StaticScoreTextBox" Text="70"/>

                        <TextBlock Text="Dynamic score" FontSize="13" Foreground="{StaticResource SecondaryText}"/>
                        <TextBox x:Name="DynamicScoreTextBox" Text="85"/>

                        <TextBlock Text="Network score" FontSize="13" Foreground="{StaticResource SecondaryText}"/>
                        <TextBox x:Name="NetworkScoreTextBox" Text="65"/>

                        <TextBlock Text="Persistence score" FontSize="13" Foreground="{StaticResource SecondaryText}"/>
                        <TextBox x:Name="PersistenceScoreTextBox" Text="80"/>

                        <TextBlock Text="Obfuscation score" FontSize="13" Foreground="{StaticResource SecondaryText}"/>
                        <TextBox x:Name="ObfuscationScoreTextBox" Text="75"/>

                        <TextBlock Text="Reputation risk score" FontSize="13" Foreground="{StaticResource SecondaryText}"/>
                        <TextBox x:Name="ReputationRiskScoreTextBox" Text="70"/>

                        <Button Content="Analyze"
                                Click="AnalyzeButton_Click"/>

                        <Button Content="Export Report"
                                Background="{StaticResource AccentTeal}"
                                Click="ExportReportButton_Click"/>

                        <Border Background="#0B1220"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14"
                                Margin="0,20,0,0">
                            <TextBlock Text="Each score must be between 0 and 100. Charts and tables are available in separate sections."
                                       Foreground="{StaticResource SecondaryText}"
                                       TextWrapping="Wrap"
                                       FontSize="13"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="22"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <UniformGrid Columns="5">
                    <RadioButton x:Name="SummaryTab"
                                 Content="Summary"
                                 GroupName="MainNavigation"
                                 IsChecked="True"
                                 Style="{StaticResource NavRadioButtonStyle}"/>

                    <RadioButton x:Name="ScoresTab"
                                 Content="Score Charts"
                                 GroupName="MainNavigation"
                                 Style="{StaticResource NavRadioButtonStyle}"/>

                    <RadioButton x:Name="RulesTab"
                                 Content="Rule Chart"
                                 GroupName="MainNavigation"
                                 Style="{StaticResource NavRadioButtonStyle}"/>

                    <RadioButton x:Name="MembershipTab"
                                 Content="Membership Model"
                                 GroupName="MainNavigation"
                                 Style="{StaticResource NavRadioButtonStyle}"/>

                    <RadioButton x:Name="ReportTab"
                                 Content="Report"
                                 GroupName="MainNavigation"
                                 Style="{StaticResource NavRadioButtonStyle}"/>
                </UniformGrid>

                <Grid Grid.Row="2">

                    <Grid Visibility="{Binding IsChecked, ElementName=SummaryTab, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <Border Background="{StaticResource CardBackground}"
                                    BorderBrush="{StaticResource CardBorder}"
                                    BorderThickness="1"
                                    CornerRadius="22"
                                    Padding="30">

                                <StackPanel>
                                    <TextBlock Text="Risk Result"
                                               FontSize="24"
                                               FontWeight="Bold"/>

                                    <TextBlock x:Name="RiskScoreTextBlock"
                                               Text="0.00/100"
                                               FontSize="58"
                                               FontWeight="Bold"
                                               Margin="0,16,0,0"/>

                                    <TextBlock x:Name="RiskLevelTextBlock"
                                               Text="No analysis yet"
                                               FontSize="26"
                                               Foreground="#38BDF8"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Background="{StaticResource CardBackground}"
                                    BorderBrush="{StaticResource CardBorder}"
                                    BorderThickness="1"
                                    CornerRadius="22"
                                    Padding="30">

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Risk Bar"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Margin="0,0,0,14"/>

                                    <ProgressBar x:Name="RiskProgressBar"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Height="36"
                                                 Value="0"/>

                                    <TextBlock x:Name="TopExplanationTextBlock"
                                               Text="Analysis summary will be displayed here."
                                               Foreground="#CBD5E1"
                                               FontSize="16"
                                               TextWrapping="Wrap"
                                               Margin="0,18,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="2"
                                Background="{StaticResource CardBackground}"
                                BorderBrush="{StaticResource CardBorder}"
                                BorderThickness="1"
                                CornerRadius="22"
                                Padding="30">

                            <StackPanel>
                                <TextBlock Text="Dashboard Overview"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Margin="0,0,0,14"/>

                                <TextBlock Text="This application does not produce a simple yes/no decision. It converts input scores into Low, Medium, and High membership degrees, then evaluates fuzzy rules and calculates the final risk score."
                                           FontSize="17"
                                           Foreground="#CBD5E1"
                                           TextWrapping="Wrap"
                                           MaxWidth="1050"/>

                                <TextBlock Text="Charts are separated into dedicated sections, so scores, activated rules, and membership models can be reviewed clearly without crowding the main screen."
                                           FontSize="17"
                                           Foreground="#CBD5E1"
                                           TextWrapping="Wrap"
                                           MaxWidth="1050"
                                           Margin="0,18,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Visibility="{Binding IsChecked, ElementName=ScoresTab, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border Background="{StaticResource CardBackground}"
                                BorderBrush="{StaticResource CardBorder}"
                                BorderThickness="1"
                                CornerRadius="22"
                                Padding="30">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Margin="0,0,0,20">
                                    <TextBlock Text="Input Score Chart"
                                               FontSize="30"
                                               FontWeight="Bold"/>

                                    <TextBlock Text="Compares Static, Dynamic, Network, Persistence, Obfuscation, and Reputation scores."
                                               Foreground="{StaticResource SecondaryText}"
                                               FontSize="15"
                                               Margin="0,5,0,0"/>
                                </StackPanel>

                                <Border Grid.Row="1"
                                        Background="#0B1220"
                                        BorderBrush="#334155"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="20">

                                    <lvc:CartesianChart x:Name="InputScoreChart"
                                                        Background="#0B1220"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Visibility="{Binding IsChecked, ElementName=RulesTab, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2*"/>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Background="{StaticResource CardBackground}"
                                BorderBrush="{StaticResource CardBorder}"
                                BorderThickness="1"
                                CornerRadius="22"
                                Padding="30">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Margin="0,0,0,20">
                                    <TextBlock Text="Activated Rule Chart"
                                               FontSize="30"
                                               FontWeight="Bold"/>

                                    <TextBlock Text="Shows the strength values of activated fuzzy rules. Rule strength ranges from 0 to 1."
                                               Foreground="{StaticResource SecondaryText}"
                                               FontSize="15"
                                               Margin="0,5,0,0"/>
                                </StackPanel>

                                <Border Grid.Row="1"
                                        Background="#0B1220"
                                        BorderBrush="#334155"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="20">

                                    <lvc:CartesianChart x:Name="RuleStrengthChart"
                                                        Background="#0B1220"/>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Background="{StaticResource CardBackground}"
                                BorderBrush="{StaticResource CardBorder}"
                                BorderThickness="1"
                                CornerRadius="22"
                                Padding="24">

                            <StackPanel>
                                <TextBlock Text="Activated Rules"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,0,0,12"/>

                                <DataGrid x:Name="RulesGrid"
                                          Height="255">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Rule" Binding="{Binding RuleName}" Width="*"/>
                                        <DataGridTextColumn Header="Output" Binding="{Binding OutputSet}" Width="130"/>
                                        <DataGridTextColumn Header="Strength" Binding="{Binding StrengthText}" Width="130"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Visibility="{Binding IsChecked, ElementName=MembershipTab, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2*"/>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Background="{StaticResource CardBackground}"
                                BorderBrush="{StaticResource CardBorder}"
                                BorderThickness="1"
                                CornerRadius="22"
                                Padding="30">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Margin="0,0,0,20">
                                    <TextBlock Text="Membership Function Model"
                                               FontSize="30"
                                               FontWeight="Bold"/>

                                    <TextBlock Text="Shows how Low, Medium, and High fuzzy sets behave across the 0-100 score range."
                                               Foreground="{StaticResource SecondaryText}"
                                               FontSize="15"
                                               Margin="0,5,0,0"/>
                                </StackPanel>

                                <Border Grid.Row="1"
                                        Background="#0B1220"
                                        BorderBrush="#334155"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="20">

                                    <lvc:CartesianChart x:Name="MembershipFunctionChart"
                                                        Background="#0B1220"/>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Background="{StaticResource CardBackground}"
                                BorderBrush="{StaticResource CardBorder}"
                                BorderThickness="1"
                                CornerRadius="22"
                                Padding="24">

                            <StackPanel>
                                <TextBlock Text="Membership Degrees"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,0,0,12"/>

                                <DataGrid x:Name="MembershipsGrid"
                                          Height="255">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Metric" Binding="{Binding Metric}" Width="*"/>
                                        <DataGridTextColumn Header="Low" Binding="{Binding LowText}" Width="110"/>
                                        <DataGridTextColumn Header="Medium" Binding="{Binding MediumText}" Width="130"/>
                                        <DataGridTextColumn Header="High" Binding="{Binding HighText}" Width="110"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Visibility="{Binding IsChecked, ElementName=ReportTab, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border Background="{StaticResource CardBackground}"
                                BorderBrush="{StaticResource CardBorder}"
                                BorderThickness="1"
                                CornerRadius="22"
                                Padding="34">

                            <StackPanel>
                                <TextBlock Text="Report Export"
                                           FontSize="31"
                                           FontWeight="Bold"
                                           Margin="0,0,0,14"/>

                                <TextBlock Text="Generates Markdown and CSV reports from the analysis result. The Markdown report can be viewed on GitHub, while the CSV file can be used for charts or data analysis."
                                           FontSize="17"
                                           Foreground="#CBD5E1"
                                           TextWrapping="Wrap"
                                           MaxWidth="1000"
                                           Margin="0,0,0,24"/>

                                <Button Content="Generate Markdown and CSV Report"
                                        Width="350"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource AccentTeal}"
                                        Click="ExportReportButton_Click"/>

                                <TextBlock Text="Generated files are saved into the reports folder in the application output directory."
                                           FontSize="15"
                                           Foreground="{StaticResource SecondaryText}"
                                           Margin="0,22,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>